{
  "name": "pigeondeck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "vite build --config vite.content.config.ts && vite build --config vite.background.config.ts",
    "dev": "concurrently \"vite build --config vite.content.config.ts --watch\" \"vite build --config vite.background.config.ts --watch\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "e2e": "playwright test",
    "i18n:check": "node scripts/i18n-check.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.268",
    "concurrently": "^8.2.2",
    "sharp": "^0.33.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
